<Window x:Class="PrecisionMotionDash.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PrecisionMotion 控制系統" Height="650" Width="1000"
        WindowStartupLocation="CenterScreen">
    <Grid Background="#0F172A">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- 左側導覽列 -->
        <StackPanel Grid.Column="0" Background="#1E293B">
            <TextBlock Text="控制系統" Foreground="#38BDF8" FontSize="18" FontWeight="Bold" Margin="20,40,20,10"/>
            <Button Content="儀表板" Margin="10" Height="35" Background="#38BDF8" Foreground="White" BorderBrush="Transparent"/>
          
            <Button Name="btnQuote" Content="報價工具 (BOM)" Margin="10" Height="35" Background="Transparent" Foreground="#94A3B8" BorderBrush="#334155" Click="btnQuote_Click"/>
        </StackPanel>

        <!-- 右側內容區 -->
        <DockPanel Grid.Column="1" Margin="20">
            <TextBlock DockPanel.Dock="Top" Text="精密位移監控系統" Foreground="White" FontSize="24" FontWeight="Bold" Margin="0,0,0,20"/>

            <!-- 下方狀態列 -->
            <UniformGrid DockPanel.Dock="Bottom" Columns="2" Height="100">
                <Border Background="#1E293B" CornerRadius="10" Margin="5" Padding="10">
                    <StackPanel>
                        <TextBlock Text="線性馬達即時溫度 (作品 B)" Foreground="#94A3B8" FontSize="12"/>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Name="txtTemp" Text="25.0 °C" Foreground="#4ADE80" FontSize="26" FontWeight="Bold"/>
                            <TextBlock Name="txtWarning" Text=" [正常]" Foreground="#4ADE80" VerticalAlignment="Bottom" Margin="10,0,0,5" FontSize="12"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
                <Border Background="#1E293B" CornerRadius="10" Margin="5" Padding="10">
                    <StackPanel>
                        <TextBlock Text="零件累積損耗成本 (作品 C 邏輯)" Foreground="#94A3B8" FontSize="12"/>
                        <TextBlock Name="txtCost" Text="$ 0.00" Foreground="#FACC15" FontSize="26" FontWeight="Bold"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- 中間主區塊 -->
            <Border Background="#1E293B" CornerRadius="15" Padding="20" VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="當前滑塊位置 (Precision Position)" Foreground="#94A3B8" FontSize="14" HorizontalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10">
                        <TextBlock Name="txtPosition" Text="0.000" Foreground="#38BDF8" FontSize="70" FontWeight="Bold"/>
                        <TextBlock Text=" μm" Foreground="#38BDF8" FontSize="20" VerticalAlignment="Bottom" Margin="5,0,0,15"/>
                    </StackPanel>

                    <Slider Name="sldPosition" Minimum="0" Maximum="1000" Value="0" 
                            Margin="30,20" Height="40"
                            ValueChanged="sldPosition_ValueChanged"/>

                    <TextBlock Name="txtStatus" Text="等待馬達指令..." Foreground="#64748B" FontSize="12" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </DockPanel>
    </Grid>
</Window>