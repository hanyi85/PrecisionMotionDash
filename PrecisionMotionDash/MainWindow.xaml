<Window x:Class="PrecisionMotionDash.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PrecisionMotion 控制系統" Height="600" Width="1000"
        WindowStartupLocation="CenterScreen">
    <Grid Background="#0F172A">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- 左側導覽列  -->
        <StackPanel Grid.Column="0" Background="#1E293B">
            <TextBlock Text="控制系統" Foreground="#38BDF8" FontSize="18" FontWeight="Bold" Margin="20,40,20,10"/>
            <Button Content="儀表板" Margin="10" Height="35" Background="#38BDF8" Foreground="White"/>
        </StackPanel>

        <!-- 右側內容區 -->
        <DockPanel Grid.Column="1" Margin="20">
        
            <TextBlock DockPanel.Dock="Top" Text="精密位移監控" Foreground="White" FontSize="24" FontWeight="Bold" Margin="0,0,0,20"/>

           
            <UniformGrid DockPanel.Dock="Bottom" Columns="2" Height="100">
                <Border Background="#1E293B" CornerRadius="10" Margin="5" Padding="10">
                    <StackPanel>
                        <TextBlock Text="馬達溫度" Foreground="#94A3B8" FontSize="12"/>
                        <TextBlock Name="txtTemp" Text="36.5 °C" Foreground="#4ADE80" FontSize="20" FontWeight="Bold"/>
                    </StackPanel>
                </Border>
                <Border Background="#1E293B" CornerRadius="10" Margin="5" Padding="10">
                    <StackPanel>
                        <TextBlock Text="預估成本" Foreground="#94A3B8" FontSize="12"/>
                        <TextBlock Name="txtCost" Text="$ 0.00" Foreground="#FACC15" FontSize="20" FontWeight="Bold"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- 中間主區塊 -->
            <Border Background="#1E293B" CornerRadius="15" Padding="20" VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="當前滑塊位置" Foreground="#94A3B8" FontSize="14" HorizontalAlignment="Center"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10">
                        <TextBlock Name="txtPosition" Text="0.000" Foreground="#38BDF8" FontSize="60" FontWeight="Bold"/>
                        <TextBlock Text=" μm" Foreground="#38BDF8" FontSize="20" VerticalAlignment="Bottom" Margin="5,0,0,12"/>
                    </StackPanel>

                    <!-- 增加滑桿的高度，確保好點選 -->
                    <Slider Name="sldPosition" Minimum="0" Maximum="1000" Value="0" 
                        Margin="30,20" Height="40"
                        ValueChanged="sldPosition_ValueChanged"/>

                    <TextBlock Text="移動滑桿模擬精密位移" Foreground="#64748B" FontSize="12" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </DockPanel>
    </Grid>


</Window>